DATABASE_URL=postgres://user:password@localhost:5432/problemmarket
PORT=4000
JWT_SECRET=change-me-in-production
# Comma-separated list for production frontend URLs
# Example: CORS_ORIGIN=https://problemmarket.vercel.app,https://www.problemmarket.com
CORS_ORIGIN=
# Use true for managed PostgreSQL providers requiring SSL (Render/Railway)
DATABASE_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
