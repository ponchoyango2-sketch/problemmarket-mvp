DATABASE_URL=postgres://user:password@localhost:5432/problemmarket
PORT=4000
JWT_SECRET=change-me-in-production
# Base URL of the frontend used by Stripe success/cancel redirects
FRONTEND_URL=http://localhost:3000
# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# OpenAI — required for AI Advisor feature
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Model to use — gpt-4o-mini is fast and cheap; gpt-4o for premium quality
OPENAI_MODEL=gpt-4o-mini
# Comma-separated list for production frontend URLs
# Example: CORS_ORIGIN=https://problemmarket.vercel.app,https://www.problemmarket.com
CORS_ORIGIN=
# Use true for managed PostgreSQL providers requiring SSL (Render/Railway)
DATABASE_SSL=false
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
